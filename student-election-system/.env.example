# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Database
DB_NAME=election
DB_USER=election_user
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme

# Cross-service origins (used for redirects/form targets across containers)
FRONTEND_ORIGIN=http://localhost:8080
BACKEND_ORIGIN=http://localhost:8081

# Optional Tailscale profile — see docs/TAILSCALE.md
# Run with: docker compose --profile tailscale up -d
TS_HOSTNAME=papohapo-election
TS_AUTHKEY=
TS_EXTRA_ARGS=--login-server=https://YOUR-HEADSCALE-URL
